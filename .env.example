# Copy this to .env for local development. Never commit .env to git.

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave unset locally to use SQLite)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Twilio (leave as-is locally to use the stub client)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WEBHOOK_URL=https://your-tunnel.ngrok.io/sms/inbound/

# App
MAX_ROOMS_PER_USER=10
SMS_IDEMPOTENCY_TTL=86400
